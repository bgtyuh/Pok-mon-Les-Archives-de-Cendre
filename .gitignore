rom/pokeemerald-expansion/*.map
rom/pokeemerald-expansion/*.gba
rom/pokeemerald-expansion/porymap.user.cfg

# Typical transient outputs
rom/pokeemerald-expansion/**/*.o
rom/pokeemerald-expansion/**/*.a
rom/pokeemerald-expansion/**/*.d

